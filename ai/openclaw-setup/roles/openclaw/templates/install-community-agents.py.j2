#!/usr/bin/env python3
"""Bulk-install community agents from awesome-openclaw-agents catalog."""
import json, subprocess, os, sys

AGENTS_JSON = '/tmp/agents-repo/agents.json'
AGENTS_DIR = '/tmp/agents-repo/agents'
OPENCLAW_HOME = '/home/node/.openclaw'
DEFAULT_MODEL = '{{ openclaw_community_agents_model }}'

# Get existing agents
result = subprocess.run(['openclaw', 'agents', 'list', '--json'], capture_output=True, text=True)
try:
    existing = {a['id'] for a in json.loads(result.stdout)}
except Exception:
    existing = set()

with open(AGENTS_JSON) as f:
    catalog = json.load(f)

installed, skipped, failed = 0, 0, 0

for agent in catalog['agents']:
    aid = agent['id']
    if aid in existing:
        skipped += 1
        continue

    cmd = [
        'openclaw', 'agents', 'add', aid,
        '--model', DEFAULT_MODEL,
        '--non-interactive',
        '--workspace', f'{OPENCLAW_HOME}/workspace',
    ]
    r = subprocess.run(cmd, capture_output=True, text=True)
    if r.returncode != 0:
        print(f'FAIL {aid}: {r.stderr[:100]}', file=sys.stderr)
        failed += 1
        continue

    # Copy SOUL.md as IDENTITY.md
    soul_path = os.path.join(AGENTS_DIR, agent['path'].replace('agents/', '', 1))
    agent_dir = f'{OPENCLAW_HOME}/agents/{aid}/agent'
    if os.path.exists(soul_path):
        os.makedirs(agent_dir, exist_ok=True)
        with open(soul_path) as sf:
            content = sf.read()
        with open(os.path.join(agent_dir, 'IDENTITY.md'), 'w') as idf:
            idf.write(content)
        subprocess.run(
            ['openclaw', 'agents', 'set-identity', '--agent', aid, '--identity-file', os.path.join(agent_dir, 'IDENTITY.md')],
            capture_output=True,
        )

    installed += 1
    if installed % 20 == 0:
        print(f'Progress: {installed} installed...')

print(f'Done: {installed} installed, {skipped} skipped, {failed} failed')
