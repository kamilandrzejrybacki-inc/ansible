# Copy to ~/.config/homelab-s3-remotes.env, chmod 600, fill in values.
# DO NOT COMMIT THIS FILE WITH SECRETS.

# Common
export HOMELAB_STORAGE_PREFIX="kamil-homelab"

# Cloudflare R2
export CLOUDFLARE_ACCOUNT_ID=""
export CLOUDFLARE_API_TOKEN=""
export R2_ACCESS_KEY_ID=""
export R2_SECRET_ACCESS_KEY=""
export R2_BUCKET="${HOMELAB_STORAGE_PREFIX}-r2-backup"
export R2_ENDPOINT_URL="https://${CLOUDFLARE_ACCOUNT_ID}.r2.cloudflarestorage.com"

# Tigris
export TIGRIS_ACCESS_KEY_ID=""
export TIGRIS_SECRET_ACCESS_KEY=""
export TIGRIS_BUCKET="${HOMELAB_STORAGE_PREFIX}-tigris-backup"
export TIGRIS_ENDPOINT_URL="https://t3.storage.dev"

# Backblaze B2
export B2_APPLICATION_KEY_ID=""
export B2_APPLICATION_KEY=""
export B2_BUCKET="${HOMELAB_STORAGE_PREFIX}-b2-backup"
export B2_S3_ENDPOINT="https://s3.eu-central-003.backblazeb2.com"  # auto-updated by script 02

# Local MinIO (in-cluster)
export MINIO_ENDPOINT="http://192.168.0.107:30910"
export MINIO_ACCESS_KEY_ID=""
export MINIO_SECRET_ACCESS_KEY=""
export MINIO_BUCKETS="backups loki mimir obsidian velero"
