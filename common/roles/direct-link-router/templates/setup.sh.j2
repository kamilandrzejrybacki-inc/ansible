#!/bin/bash
# Managed by Ansible (role: direct-link-router, peer: {{ direct_link_peer_label }})
# Idempotent: safe to re-run on every boot.
set -u

LAN={{ direct_link_lan_iface }}
USB={{ direct_link_usb_iface }}
ALIAS={{ direct_link_router_alias_ip }}/{{ direct_link_router_alias_prefix }}

/usr/sbin/sysctl -w net.ipv4.ip_forward=1
/usr/sbin/sysctl -w net.ipv4.conf.all.proxy_arp=1
/usr/sbin/sysctl -w "net.ipv4.conf.${LAN}.proxy_arp=1"
/usr/sbin/sysctl -w "net.ipv4.conf.${USB}.proxy_arp=1"

/sbin/ip link show "${USB}" >/dev/null 2>&1 && /sbin/ip link set "${USB}" up

/sbin/ip addr show dev "${USB}" | grep -q "${ALIAS}" \
  || /sbin/ip addr add "${ALIAS}" dev "${USB}" noprefixroute

{% for peer in direct_link_peer_ips %}
/sbin/ip route replace {{ peer }}/32 dev "${USB}"
{% endfor %}

for chain_arg in "-i ${LAN} -o ${USB}" "-i ${USB} -o ${LAN}"; do
  /usr/sbin/iptables -C {{ direct_link_iptables_chain }} ${chain_arg} -j ACCEPT 2>/dev/null \
    || /usr/sbin/iptables -I {{ direct_link_iptables_chain }} 1 ${chain_arg} -j ACCEPT
done

exit 0
