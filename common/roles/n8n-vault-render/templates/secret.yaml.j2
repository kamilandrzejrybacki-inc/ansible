{# Managed by Ansible (role: n8n-vault-render) — do not edit manually.

    Vars expected:
      _primary_data    dict   keys from VAULT_KV_PATH (e.g. homelab/n8n)
      _postgres_data   dict   keys from homelab/n8n-postgres (encryption_key,
                              db_password, redis_password)
      _primary_leaf    str    last segment of the primary path ("n8n")
      _service_results list   `uri` register results for sibling services;
                              each item has `.item` (service name) and `.json.data.data`
      n8n_vault_excluded_keys list  keys to drop from primary + service payloads

    Output: stringData block with sorted keys.
#}
{%- set payload = {} -%}
{%- set _ = payload.update({
    'N8N_ENCRYPTION_KEY': _postgres_data.encryption_key,
    'DB_POSTGRESDB_PASSWORD': _postgres_data.db_password,
    'QUEUE_BULL_REDIS_PASSWORD': _postgres_data.redis_password,
}) -%}
{%- for key, value in _primary_data.items() -%}
  {%- if key not in n8n_vault_excluded_keys -%}
    {%- set _ = payload.update({key: value}) -%}
  {%- endif -%}
{%- endfor -%}
{%- for svc in _service_results -%}
  {%- if svc.status | default(200) == 200 and svc.item != _primary_leaf -%}
    {%- for key, value in svc.json.data.data.items() -%}
      {%- if key not in n8n_vault_excluded_keys -%}
        {%- set prefixed = svc.item ~ '_' ~ key -%}
        {%- if prefixed not in payload -%}
          {%- set _ = payload.update({prefixed: value}) -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
{%- endfor -%}
# Managed by Ansible (role: n8n-vault-render) — do not edit manually.
apiVersion: v1
kind: Namespace
metadata:
  name: {{ n8n_main_namespace }}
---
apiVersion: v1
kind: Secret
metadata:
  name: {{ n8n_main_secret_name }}
  namespace: {{ n8n_main_namespace }}
  labels:
    app.kubernetes.io/managed-by: ansible-n8n-vault-render
type: Opaque
stringData:
{% for key in payload.keys() | sort %}
  {{ key }}: {{ payload[key] | string | to_json }}
{% endfor %}
