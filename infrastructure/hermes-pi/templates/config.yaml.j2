model:
  default: "{{ hermes_model }}"
  provider: "{{ hermes_provider }}"

smart_model_routing:
  enabled: false

memory:
  memory_enabled: true
  user_profile_enabled: true
  memory_char_limit: 2200
  user_char_limit: 1375

mcp_servers:
  cellarette:
    url: "{{ hermes_cellarette_url }}"
  n8n:
    url: "http://192.168.0.108:5678/mcp-server/http"
    headers:
      Authorization: "Bearer {{ n8n_mcp_token }}"

platform_toolsets:
  telegram: [hermes-telegram]

session_reset:
  mode: both
  idle_minutes: 1440
  at_hour: 4

knowledge_sources:
  - name: supermemory
    type: supermemory
    url: "http://hermes-supermemory:3100"
    order: 1
    modes: [bulk, per_turn]

  - name: dreaming
    type: dreaming
    order: 2
    modes: [bulk]

  - name: distillery
    type: distillery
    url: "{{ distillery_url }}"
    order: 3
    modes: [bulk, per_turn, on_demand]
    options:
      limit: 5
      api_key: "{{ distillery_api_key }}"

  - name: skills
    type: skills
    order: 4
    modes: [bulk]
    options:
      path: "/app/skills"
