services:
  redis:
    image: redis:7-alpine
    container_name: hermes-redis
    restart: unless-stopped
    volumes:
      - redis-data:/data
    command: redis-server --save 60 1 --maxmemory 32mb --maxmemory-policy allkeys-lru
    networks:
      - hermes

  webui:
    image: {{ hermes_registry }}/hermes-webui-fork:{{ hermes_webui_fork_tag }}
    container_name: hermes-webui
    restart: unless-stopped
    depends_on:
      - redis
    command: >
      sh -c "
        apt-get update -qq && apt-get install -y -qq --no-install-recommends openssh-client nodejs npm git 2>/dev/null;
        pip install --no-cache-dir -q openai anthropic fire rich python-dotenv httpx pyyaml tiktoken 2>/dev/null;
        sed -i \"s/'openai-codex': \\[/'openai-codex': [\\n        {'id': '{{ hermes_model }}', 'label': '{{ hermes_model }}'},/\" /app/api/config.py;
        python3 /opt/data/patch_streaming.py;
        exec python server.py
      "
    ports:
      - "8788:8788"
    volumes:
      - ./data:/opt/data
      - ./data/webui-state:/data
      - ./agent-code:/agent-code/hermes:ro
      - ./data/.ssh:/root/.ssh
    environment:
      - HERMES_HOME=/opt/data
      - HERMES_CONFIG_PATH=/opt/data/config.yaml
      - HERMES_WEBUI_AGENT_DIR=/agent-code/hermes
      - HERMES_WEBUI_DEFAULT_MODEL={{ hermes_model }}
      - HERMES_WEBUI_HOST=0.0.0.0
      - HERMES_WEBUI_PORT=8788
    env_file:
      - .env
    networks:
      - hermes

  broker:
    image: python:3.12-slim
    container_name: hermes-broker
    restart: unless-stopped
    depends_on:
      - redis
      - webui
    command: >
      sh -c "
        pip install --no-cache-dir -q redis 2>/dev/null;
        exec python /app/message_broker.py
      "
    ports:
      - "8789:8789"
    volumes:
      - ./message_broker.py:/app/message_broker.py:ro
    environment:
      - WEBUI_URL=http://hermes-webui:8788
      - REDIS_URL=redis://redis:6379/0
      - SSE_PORT=8789
      - POLL_INTERVAL=2
    networks:
      - hermes

  telegram-bridge:
    image: python:3.12-slim
    container_name: hermes-telegram-bridge
    restart: unless-stopped
    depends_on:
      - redis
      - webui
    command: >
      sh -c "
        pip install --no-cache-dir -q python-telegram-bot httpx redis 2>/dev/null;
        exec python /app/telegram_bridge.py
      "
    volumes:
      - ./data:/opt/data
      - ./telegram_bridge.py:/app/telegram_bridge.py:ro
    environment:
      - WEBUI_URL=http://hermes-webui:8788
      - REDIS_URL=redis://redis:6379/0
      - HERMES_MODEL={{ hermes_model }}
      - TELEGRAM_ALLOWED_USERS={{ telegram_allowed_user_id }}
    env_file:
      - .env
    networks:
      - hermes

  hermes-dreaming:
    image: {{ hermes_registry }}/hermes-dreaming:{{ hermes_dreaming_tag }}
    container_name: hermes-dreaming
    restart: unless-stopped
    depends_on:
      - redis
    volumes:
      - ./data:/opt/data
    environment:
      - HERMES_MEMORIES_DIR=/opt/data/memories
      - DREAMING_ENABLED={{ memory_source_dreaming_enabled | lower }}
      - DREAMING_LOOKBACK_DAYS={{ dreaming_lookback_days }}
      - DREAMING_CRON={{ dreaming_cron }}
    env_file:
      - .env
    networks:
      - hermes

  supermemory:
    image: python:3.12-slim
    container_name: hermes-supermemory
    restart: unless-stopped
    command: python /app/supermemory_server.py
    volumes:
      - ./supermemory_server.py:/app/supermemory_server.py:ro
      - supermemory-data:/data
    environment:
      - PORT=3100
      - SUPERMEMORY_DATA_FILE=/data/memories.json
    env_file:
      - .env
    networks:
      - hermes

  cellarette:
    image: {{ hermes_registry }}/cellarette:{{ hermes_cellarette_tag }}
    container_name: hermes-cellarette
    restart: unless-stopped
    volumes:
      - ./cellarette.yaml:/etc/cellarette/cellarette.yaml:ro
    environment:
      - CELLARETTE_CONFIG=/etc/cellarette/cellarette.yaml
    networks:
      - hermes

  omniroute-proxy:
    image: nginx:alpine
    container_name: hermes-omniroute-proxy
    restart: unless-stopped
    ports:
      - "8787:8787"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
    networks:
      - hermes

volumes:
  redis-data:
  supermemory-data:

networks:
  hermes:
    driver: bridge
