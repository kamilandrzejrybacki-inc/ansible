#!/usr/bin/env python3
"""
Lightweight Supermemory-compatible HTTP server.
Implements GET/POST /api/memories backed by a JSON file.
Runs as hermes-supermemory sidecar on lw-pi.
"""
import json
import os
import time
import uuid
from http.server import BaseHTTPRequestHandler, HTTPServer
from pathlib import Path

DATA_FILE = Path(os.environ.get("SUPERMEMORY_DATA_FILE", "/data/memories.json"))
PORT      = int(os.environ.get("PORT", "3100"))
API_KEY   = os.environ.get("SUPERMEMORY_API_KEY", "")


def _load() -> list:
    if DATA_FILE.exists():
        try:
            return json.loads(DATA_FILE.read_text())
        except Exception:
            pass
    return []


def _save(memories: list) -> None:
    DATA_FILE.parent.mkdir(parents=True, exist_ok=True)
    DATA_FILE.write_text(json.dumps(memories, indent=2, ensure_ascii=False))


def _auth_ok(headers) -> bool:
    if not API_KEY or API_KEY == "placeholder":
        return True
    auth = headers.get("Authorization", "")
    return auth == f"Bearer {API_KEY}"


class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        print(f"[supermemory] {self.address_string()} {fmt % args}", flush=True)

    def _send(self, code: int, body: dict) -> None:
        data = json.dumps(body, ensure_ascii=False).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def do_GET(self):
        if self.path == "/health":
            self._send(200, {"status": "ok"})
            return
        if self.path.startswith("/api/memories"):
            if not _auth_ok(self.headers):
                self._send(401, {"error": "Unauthorized"})
                return
            memories = _load()
            self._send(200, {"memories": memories, "total": len(memories)})
            return
        self._send(404, {"error": "not found"})

    def do_POST(self):
        if self.path == "/api/memories":
            if not _auth_ok(self.headers):
                self._send(401, {"error": "Unauthorized"})
                return
            length = int(self.headers.get("Content-Length", 0))
            try:
                body = json.loads(self.rfile.read(length))
            except Exception:
                self._send(400, {"error": "invalid JSON"})
                return
            content = body.get("content", "").strip()
            if not content:
                self._send(400, {"error": "content required"})
                return
            memories = _load()
            entry = {
                "id":        str(uuid.uuid4()),
                "content":   content,
                "title":     body.get("title") or content[:60],
                "tags":      body.get("tags", []),
                "createdAt": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
                "updatedAt": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
            }
            memories.append(entry)
            _save(memories)
            self._send(201, {"memory": entry})
            return
        self._send(404, {"error": "not found"})

    def do_DELETE(self):
        prefix = "/api/memories/"
        if self.path.startswith(prefix):
            mid = self.path[len(prefix):]
            memories = _load()
            filtered = [m for m in memories if m.get("id") != mid]
            if len(filtered) == len(memories):
                self._send(404, {"error": "not found"})
                return
            _save(filtered)
            self._send(200, {"deleted": mid})
            return
        self._send(404, {"error": "not found"})


if __name__ == "__main__":
    print(f"[supermemory] starting on port {PORT}, data={DATA_FILE}", flush=True)
    HTTPServer(("0.0.0.0", PORT), Handler).serve_forever()
