"""Telegram ↔ Hermes WebUI bidirectional bridge.

- Telegram messages → webui /api/chat/start → response back to Telegram
- WebUI messages → polled from session API → mirrored to Telegram
Both interfaces see the full conversation.
"""

import asyncio
import json
import logging
import os
import time
import urllib.request
import urllib.error
from pathlib import Path

import httpx
from telegram import Update
from telegram.ext import (
    Application,
    CommandHandler,
    MessageHandler,
    filters,
)
from telegram.constants import ParseMode

logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(name)s] %(message)s")
log = logging.getLogger("tg-bridge")

WEBUI_URL = os.environ.get("WEBUI_URL", "http://hermes-webui:8788")
BOT_TOKEN = os.environ["TELEGRAM_BOT_TOKEN"]
ALLOWED_USERS = {int(u) for u in os.environ.get("TELEGRAM_ALLOWED_USERS", "").split(",") if u.strip()}
MODEL = os.environ.get("HERMES_MODEL", "gpt-5.3-codex")
POLL_INTERVAL = int(os.environ.get("POLL_INTERVAL", "3"))

# State: Telegram user_id → session info
_sessions: dict[int, dict] = {}  # {user_id: {"session_id": str, "chat_id": int, "msg_count": int}}
_sessions_file = Path("/opt/data/telegram_sessions.json")
# Track stream_ids initiated by the bridge so we don't mirror them back
_bridge_streams: set[str] = set()


def _load_sessions():
    global _sessions
    try:
        with open(_sessions_file) as f:
            _sessions = {int(k): v for k, v in json.load(f).items()}
    except (FileNotFoundError, json.JSONDecodeError):
        _sessions = {}


def _save_sessions():
    with open(_sessions_file, "w") as f:
        json.dump({str(k): v for k, v in _sessions.items()}, f)


def _webui_get(path: str) -> dict:
    """Blocking GET to webui API."""
    r = urllib.request.urlopen(f"{WEBUI_URL}{path}", timeout=30)
    return json.loads(r.read().decode())


def _webui_post(path: str, body: dict) -> dict:
    """Blocking POST to webui API."""
    data = json.dumps(body).encode()
    req = urllib.request.Request(
        f"{WEBUI_URL}{path}",
        data=data,
        headers={"Content-Type": "application/json"},
    )
    r = urllib.request.urlopen(req, timeout=30)
    return json.loads(r.read().decode())


async def _get_or_create_session(user_id: int, chat_id: int) -> str:
    """Get existing session or create a new one via the webui API."""
    if user_id in _sessions:
        _sessions[user_id]["chat_id"] = chat_id
        return _sessions[user_id]["session_id"]

    loop = asyncio.get_event_loop()
    resp = await loop.run_in_executor(None, _webui_post, "/api/session/new", {})
    sid = resp["session"]["session_id"]
    msg_count = len(resp["session"].get("messages", []))

    _sessions[user_id] = {"session_id": sid, "chat_id": chat_id, "msg_count": msg_count}
    _save_sessions()
    log.info("Created session %s for user %d", sid, user_id)
    return sid


def _read_sse_sync(stream_id: str) -> str:
    """Read SSE stream using urllib (handles HTTP/1.0 servers correctly)."""
    url = f"{WEBUI_URL}/api/chat/stream?stream_id={stream_id}"
    req = urllib.request.Request(url)
    tokens = []
    tool_calls = []

    with urllib.request.urlopen(req, timeout=300) as resp:
        event_type = ""
        data_str = ""
        for raw_line in resp:
            line = raw_line.decode("utf-8", errors="replace").rstrip("\n\r")

            if line.startswith("event:"):
                event_type = line[6:].strip()
            elif line.startswith("data:"):
                data_str = line[5:].strip()
            elif line == "":
                if event_type and data_str:
                    try:
                        data = json.loads(data_str)
                    except json.JSONDecodeError:
                        event_type = data_str = ""
                        continue

                    if event_type == "token":
                        tokens.append(data.get("text", ""))
                    elif event_type == "tool":
                        tool_calls.append(data.get("name", "unknown"))
                    elif event_type in ("done", "error", "apperror", "cancel"):
                        if event_type in ("error", "apperror"):
                            return f"⚠️ Error: {data.get('message', 'unknown error')}"
                        if event_type == "cancel":
                            return "❌ Cancelled"
                        break
                event_type = data_str = ""

    response = "".join(tokens).strip()
    if not response and tool_calls:
        response = "🔧 " + ", ".join(tool_calls)
    return response or "(no response)"


async def _send_and_stream(session_id: str, message: str) -> str:
    """Send message to webui and collect the full streamed response."""
    loop = asyncio.get_event_loop()
    resp = await loop.run_in_executor(
        None, _webui_post, "/api/chat/start",
        {"session_id": session_id, "message": message, "model": MODEL, "workspace": "/opt/data"},
    )
    stream_id = resp["stream_id"]
    _bridge_streams.add(stream_id)
    result = await loop.run_in_executor(None, _read_sse_sync, stream_id)
    _bridge_streams.discard(stream_id)
    return result


def _truncate(text: str, max_len: int = 4096) -> str:
    if len(text) <= max_len:
        return text
    return text[: max_len - 20] + "\n\n… (truncated)"


# ── Telegram handlers ─────────────────────────────────────────────────

async def cmd_start(update: Update, _):
    if ALLOWED_USERS and update.effective_user.id not in ALLOWED_USERS:
        return
    await update.message.reply_text(
        "👋 Connected to Truteń via WebUI bridge.\n"
        "Messages sync between Telegram and web UI.\n"
        "Use /new to start a fresh session."
    )


async def cmd_new(update: Update, _):
    if ALLOWED_USERS and update.effective_user.id not in ALLOWED_USERS:
        return
    uid = update.effective_user.id
    _sessions.pop(uid, None)
    _save_sessions()
    sid = await _get_or_create_session(uid, update.effective_chat.id)
    await update.message.reply_text(f"🆕 New session: {sid[:8]}…")


async def handle_message(update: Update, _):
    if ALLOWED_USERS and update.effective_user.id not in ALLOWED_USERS:
        return
    uid = update.effective_user.id
    text = update.message.text or ""
    if not text.strip():
        return

    sid = await _get_or_create_session(uid, update.effective_chat.id)
    thinking = await update.message.reply_text("⏳ Thinking…")

    try:
        response = await _send_and_stream(sid, text)
        # Update msg_count so the poller doesn't re-mirror these messages
        loop = asyncio.get_event_loop()
        session_data = await loop.run_in_executor(
            None, _webui_get, f"/api/session?session_id={sid}"
        )
        _sessions[uid]["msg_count"] = len(session_data["session"].get("messages", []))
        _save_sessions()
        await thinking.edit_text(_truncate(response))
    except Exception as e:
        log.exception("Error processing message")
        if "not found" in str(e).lower() or "404" in str(e):
            _sessions.pop(uid, None)
            sid = await _get_or_create_session(uid, update.effective_chat.id)
            try:
                response = await _send_and_stream(sid, text)
                _sessions[uid]["msg_count"] = 999  # will be corrected on next poll
                _save_sessions()
                await thinking.edit_text(_truncate(response))
            except Exception as e2:
                await thinking.edit_text(f"⚠️ Error: {e2}")
        else:
            await thinking.edit_text(f"⚠️ Error: {e}")


# ── WebUI → Telegram poller ───────────────────────────────────────────

async def _poll_webui_sessions(app):
    """Background task: check for new messages added via web UI and mirror to Telegram."""
    bot = app.bot
    while True:
        await asyncio.sleep(POLL_INTERVAL)
        for uid, info in list(_sessions.items()):
            sid = info.get("session_id")
            chat_id = info.get("chat_id")
            last_count = info.get("msg_count", 0)
            if not sid or not chat_id:
                continue
            try:
                loop = asyncio.get_event_loop()
                data = await loop.run_in_executor(
                    None, _webui_get, f"/api/session?session_id={sid}"
                )
                messages = data["session"].get("messages", [])
                current_count = len(messages)

                if current_count > last_count:
                    new_msgs = messages[last_count:]
                    for msg in new_msgs:
                        role = msg.get("role", "")
                        content = str(msg.get("content", "")).strip()
                        if not content:
                            continue
                        if role == "user":
                            text = f"🌐 *You (web):*\n{content}"
                        elif role == "assistant":
                            text = f"🤖 *Truteń (web):*\n{content}"
                        else:
                            continue
                        try:
                            await bot.send_message(
                                chat_id=chat_id,
                                text=_truncate(text),
                            )
                        except Exception as send_err:
                            log.warning("Failed to mirror message to Telegram: %s", send_err)

                    _sessions[uid]["msg_count"] = current_count
                    _save_sessions()

            except Exception as e:
                log.debug("Poll error for session %s: %s", sid, e)


def main():
    _load_sessions()
    app = Application.builder().token(BOT_TOKEN).build()
    app.add_handler(CommandHandler("start", cmd_start))
    app.add_handler(CommandHandler("new", cmd_new))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_message))

    async def post_init(application):
        asyncio.create_task(_poll_webui_sessions(application))

    app.post_init = post_init

    log.info("Telegram bridge started (webui=%s, poll=%ds, allowed=%s)", WEBUI_URL, POLL_INTERVAL, ALLOWED_USERS or "all")
    app.run_polling(allowed_updates=Update.ALL_TYPES)


if __name__ == "__main__":
    main()
