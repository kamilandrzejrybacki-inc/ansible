apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {{ item.name }}
  namespace: {{ argocd_apps_namespace }}
spec:
  project: default
  source:
    repoURL: {{ argocd_apps_repo }}
    targetRevision: {{ argocd_apps_target_revision }}
    path: {{ item.chart_path }}
  destination:
    server: https://kubernetes.default.svc
    namespace: {{ item.namespace }}
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
