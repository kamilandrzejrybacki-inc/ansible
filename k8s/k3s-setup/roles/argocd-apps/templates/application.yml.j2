apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {{ item.name }}
  namespace: {{ argocd_apps_namespace }}
spec:
  project: default
  source:
    repoURL: {{ argocd_apps_repo }}
    targetRevision: {{ argocd_apps_target_revision }}
    path: {{ item.chart_path }}
{% if item.helm_parameters | default([]) %}
    helm:
      parameters:
{% for p in item.helm_parameters %}
        - name: "{{ p.name }}"
          value: "{{ p.value }}"
{% endfor %}
{% endif %}
  destination:
    server: https://kubernetes.default.svc
    namespace: {{ item.namespace }}
{% if item.ignore_differences | default([]) %}
  ignoreDifferences:
{% for d in item.ignore_differences %}
    - group: "{{ d.group | default('') }}"
      kind: "{{ d.kind }}"
{% if d.name is defined %}
      name: "{{ d.name }}"
{% endif %}
{% if d.namespace is defined %}
      namespace: "{{ d.namespace }}"
{% endif %}
{% if d.json_pointers | default([]) %}
      jsonPointers:
{% for p in d.json_pointers %}
        - "{{ p }}"
{% endfor %}
{% endif %}
{% if d.jq_path_expressions | default([]) %}
      jqPathExpressions:
{% for p in d.jq_path_expressions %}
        - "{{ p }}"
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}
  syncPolicy:
{% if not (item.no_auto_sync | default(false)) %}
    automated:
      prune: true
      selfHeal: {{ item.self_heal | default(true) | lower }}
{% endif %}
    syncOptions:
      - CreateNamespace=true
