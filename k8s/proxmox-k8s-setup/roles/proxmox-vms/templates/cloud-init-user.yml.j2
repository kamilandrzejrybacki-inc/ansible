#cloud-config
hostname: {{ _vm_hostname }}
fqdn: {{ _vm_hostname }}.{{ _cluster.name }}
manage_etc_hosts: true

users:
  - name: {{ vm_ssh_user }}
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    ssh_authorized_keys:
      - {{ cloudinit_ssh_public_key }}

package_update: true
packages:
  - qemu-guest-agent

runcmd:
  - systemctl enable --now qemu-guest-agent
