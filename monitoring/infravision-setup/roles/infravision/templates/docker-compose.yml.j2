services:
  web:
    image: nginx:alpine
    container_name: {{ infravision_container_name }}
    restart: unless-stopped
    ports:
      - "{{ infravision_port }}:8080"
    volumes:
      - site-data:/usr/share/nginx/html:ro
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro

volumes:
  site-data:
