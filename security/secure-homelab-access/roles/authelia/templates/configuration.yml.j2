---
theme: "dark"

server:
  address: "tcp://0.0.0.0:9091"
  buffers:
    read: 65536
    write: 65536

log:
  level: "info"

telemetry:
  metrics:
    enabled: true
    address: "tcp://0.0.0.0:9959"

totp:
  issuer: "{{ domain }}"
  period: 30
  skew: 1

webauthn:
  display_name: "{{ domain }}"

authentication_backend:
  file:
    path: "/config/users_database.yml"
    password:
      algorithm: "bcrypt"

access_control:
  default_policy: "deny"
  networks:
    - name: vpn_and_lan
      networks:
        - "{{ vpn_subnet }}"   # WireGuard VPN clients
        - "192.168.0.0/24"        # NAS direct link
        - "192.168.0.0/16"     # LAN (home network)
    - name: docker_internal
      networks:
        - "172.20.0.0/24"      # homelab-net (Lightpanda, internal agents)
  rules:
    # Docker internal: full bypass — containers on homelab-net skip auth entirely
    - domain: "*.{{ domain }}"
      networks: [docker_internal]
      policy: "bypass"
    # VPN / LAN: single factor — no TOTP required when on WireGuard or home network
    - domain: "*.{{ domain }}"
      networks: [vpn_and_lan]
      policy: "one_factor"
    # Nexterm: one-factor from any network — Nexterm has its own OIDC auth layer
    - domain: "{{ nexterm_hostname | default('nexterm') }}.{{ domain }}"
      policy: "one_factor"
    # Grafana API: bypass for token auth (Grizzly, GitHub Actions CI/CD)
    - domain: "grafana.{{ domain }}"
      resources:
        - "^/api/.*"
      policy: "bypass"
    # Open Design: brand assets (logos/icons) + PWA chrome are fetched by the
    # browser WITHOUT credentials, so they arrive anonymous and 401 under any
    # gate — bypass the raw-asset reads (low sensitivity). Gate the rest at one
    # factor (no TOTP wall; the app itself has no internal auth).
    - domain: "design.{{ domain }}"
      resources:
        - "^/api/projects/.*/raw/.*"
        - "^/(favicon|manifest|apple-touch-icon|icon-maskable).*"
      policy: "bypass"
    - domain: "design.{{ domain }}"
      policy: "one_factor"
    # WAN: full two-factor
    - domain: "*.{{ domain }}"
      policy: "two_factor"

session:
  name: "authelia_session"
  secret: "{{ authelia_session_secret }}"
  expiration: "720h"    # 30 days
  inactivity: "720h"    # reset on activity
  remember_me: "720h"   # stay logged in for 30 days
  cookies:
    - domain: "{{ domain }}"
      authelia_url: "https://{{ subdomain_auth }}.{{ domain }}"
      default_redirection_url: "https://{{ subdomain_home }}.{{ domain }}"
      same_site: "lax"

storage:
  encryption_key: "{{ authelia_storage_encryption_key }}"
  local:
    path: "/config/db.sqlite3"

identity_validation:
  reset_password:
    jwt_secret: "{{ authelia_jwt_secret }}"

notifier:
{% if authelia_smtp_password | default('') %}
  smtp:
    address: "smtp://{{ authelia_smtp_host | default('smtp.gmail.com') }}:{{ authelia_smtp_port | default(587) }}"
    username: "{{ authelia_smtp_username }}"
    password: "{{ authelia_smtp_password }}"
    sender: "Authelia <{{ authelia_smtp_username }}>"
    subject: "[Authelia] {title}"
    startup_check_address: "{{ authelia_smtp_username }}"
{% else %}
  filesystem:
    filename: "/config/notification.txt"
{% endif %}

regulation:
  max_retries: 3
  find_time: "2m"
  ban_time: "1h"

# =============================================================================
# OIDC Provider
# Authelia acts as the identity provider. Services that support OIDC redirect
# here for login; if a session already exists the user is auto-approved with
# no credential prompt.
# =============================================================================
{% if authelia_oidc_hmac_secret | default('') %}
identity_providers:
  oidc:
    hmac_secret: "{{ authelia_oidc_hmac_secret }}"
    jwks:
      - key: |
          {{ authelia_oidc_jwk_key | indent(10) }}
        algorithm: RS256

    clients:

      # Grafana — Generic OAuth2/OIDC
      - client_id: grafana
        client_name: Grafana
        client_secret: "{{ authelia_oidc_client_secret_grafana_hash | default('') }}"
        public: false
        authorization_policy: one_factor
        scopes: [openid, profile, email, groups]
        redirect_uris:
          - "https://{{ grafana_hostname | default('grafana') }}.{{ domain }}/login/generic_oauth"
        response_types: [code]
        grant_types: [authorization_code]
        userinfo_signed_response_alg: none

      # Outline — built-in OIDC support
      - client_id: outline
        client_name: Outline
        client_secret: "{{ authelia_oidc_client_secret_outline_hash | default('') }}"
        public: false
        authorization_policy: one_factor
        scopes: [openid, profile, email]
        redirect_uris:
          - "https://{{ outline_hostname | default('outline') }}.{{ domain }}/auth/oidc.callback"
        response_types: [code]
        grant_types: [authorization_code]
        userinfo_signed_response_alg: none

      # HashiCorp Vault — native OIDC auth method
      - client_id: vault
        client_name: HashiCorp Vault
        client_secret: "{{ authelia_oidc_client_secret_vault_hash | default('') }}"
        public: false
        authorization_policy: one_factor
        scopes: [openid, profile, email]
        redirect_uris:
          - "https://{{ vault_hostname | default('hashi-vault') }}.{{ domain }}/ui/vault/auth/oidc/oidc/callback"
          - "http://localhost:8250/oidc/callback"
        response_types: [code]
        grant_types: [authorization_code]
        userinfo_signed_response_alg: none

      # Nexterm — web SSH terminal manager
      - client_id: nexterm
        client_name: Nexterm
        client_secret: "{{ authelia_oidc_client_secret_nexterm_hash | default('') }}"
        public: false
        authorization_policy: one_factor
        consent_mode: implicit
        scopes: [openid, profile, email]
        redirect_uris:
          # Nexterm's DB sends /api/oidc/callback in the authorization request; a
          # Traefik middleware (nexterm-oidc-path-fix) rewrites it to the real
          # backend route /api/auth/oidc/callback. Authelia must register the URL
          # Nexterm SENDS (/api/oidc/callback) or it rejects with redirect_uri
          # mismatch. Both registered so either route validates.
          - "https://{{ nexterm_hostname | default('nexterm') }}.{{ domain }}/api/oidc/callback"
          - "https://{{ nexterm_hostname | default('nexterm') }}.{{ domain }}/api/auth/oidc/callback"
        response_types: [code]
        grant_types: [authorization_code]
        token_endpoint_auth_method: client_secret_post
        userinfo_signed_response_alg: none

      # GlitchTip — error tracking (django-allauth generic OIDC, provider id "authelia")
      - client_id: glitchtip
        client_name: GlitchTip
        client_secret: "{{ authelia_oidc_client_secret_glitchtip_hash | default('$plaintext$GLITCHTIP_SECRET_UNSET') }}"
        public: false
        authorization_policy: one_factor
        consent_mode: implicit
        scopes: [openid, profile, email]
        redirect_uris:
          - "https://{{ subdomain_glitchtip | default('glitchtip') }}.{{ domain }}/accounts/oidc/authelia/login/callback/"
        response_types: [code]
        grant_types: [authorization_code]
        token_endpoint_auth_method: client_secret_basic
        userinfo_signed_response_alg: none

      # Pingvin Share — file sharing
      - client_id: pingvin-share
        client_name: Pingvin Share
        client_secret: "{{ authelia_oidc_client_secret_pingvin_hash | default('') }}"
        public: false
        authorization_policy: one_factor
        consent_mode: implicit
        scopes: [openid, profile, email, groups]
        redirect_uris:
          - "https://{{ subdomain_filebrowser | default('files') }}.{{ domain }}/api/oauth/callback/oidc"
        response_types: [code]
        grant_types: [authorization_code]
        token_endpoint_auth_method: client_secret_basic
        userinfo_signed_response_alg: none

      # ArgoCD — GitOps continuous delivery
      - client_id: argocd
        client_name: ArgoCD
        client_secret: "{{ authelia_oidc_client_secret_argocd_hash | default('') }}"
        public: false
        authorization_policy: one_factor
        consent_mode: implicit
        scopes: [openid, profile, email, groups]
        redirect_uris:
          - "https://{{ subdomain_argocd | default('argocd') }}.{{ domain }}/auth/callback"
        response_types: [code]
        grant_types: [authorization_code]
        userinfo_signed_response_alg: none

{% endif %}
