# Cellarette MCP gateway admin UI (K8s on lw-c1, admin port)
{{ _scheme }}{{ subdomain_cellarette }}.{{ domain }} {
	import rate_limit
	import proxy_headers
{% if cloudflare_api_token | default('') and not cf_tunnel_name | default('') %}
	import cf_tls
{% endif %}
	import authelia
	# Inject shared secret AFTER Authelia validates. Caddy's request_header runs
	# after forward_auth in the handler chain, so this header reaches the backend
	# only on authenticated requests. cellarette trusts the session only when this
	# matches — blocks NodePort spoofing without needing to strip Remote-User.
	request_header +X-Cellarette-Authelia {env.CELLARETTE_AUTHELIA_SECRET}
	redir / /admin/ 302
	reverse_proxy http://{{ k8s_node_ip }}:{{ cellarette_nodeport | default(30701) }}
}

# Cellarette MCP gateway — SSE endpoint for Claude Code / MCP clients.
# NO Authelia: SSE clients cannot complete a browser SSO flow. Gated instead
# by a static Bearer token (Vault homelab/cellarette.mcp_token) that clients
# send as an Authorization header. Backend is the Traefik IngressRoute
# (charts/cellarette/templates/ingressroute.yaml) — the MCP Service itself
# stays ClusterIP, no NodePort (hardening 2026-05-29 preserved).
# SSE needs unbuffered streaming + no read timeout, same as hermes/nexterm.
{{ _scheme }}{{ subdomain_cellarette_mcp }}.{{ domain }} {
	import rate_limit
	import proxy_headers
{% if cloudflare_api_token | default('') and not cf_tunnel_name | default('') %}
	import cf_tls
{% endif %}
	@unauthorized not header Authorization "Bearer {env.CELLARETTE_MCP_TOKEN}"
	respond @unauthorized "Unauthorized" 401
	reverse_proxy http://{{ traefik_vip | default('192.168.0.50') }} {
		flush_interval -1
		transport http {
			read_timeout 0
			write_timeout 0
		}
	}
}
