# Cellarette MCP gateway admin UI (K8s on lw-c1, admin port)
{{ _scheme }}{{ subdomain_cellarette }}.{{ domain }} {
	import rate_limit
	import proxy_headers
{% if cloudflare_api_token | default('') and not cf_tunnel_name | default('') %}
	import cf_tls
{% endif %}
	import authelia
	# Inject shared secret AFTER Authelia validates. Caddy's request_header runs
	# after forward_auth in the handler chain, so this header reaches the backend
	# only on authenticated requests. cellarette trusts the session only when this
	# matches — blocks NodePort spoofing without needing to strip Remote-User.
	request_header +X-Cellarette-Authelia {env.CELLARETTE_AUTHELIA_SECRET}
	redir / /admin/ 302
	reverse_proxy http://{{ k8s_node_ip }}:{{ cellarette_nodeport | default(30701) }}
}

# Sentinel (incident dashboard — via Traefik IngressRoute).
# /webhook/* is the Grafana alert ingress; it has its own SENTINEL_WEBHOOK_SECRET
# HMAC check, so Authelia must NOT block those POSTs.
{{ _scheme }}{{ subdomain_sentinel | default('sentinel') }}.{{ domain }} {
	import rate_limit
	import proxy_headers
{% if cloudflare_api_token | default('') and not cf_tunnel_name | default('') %}
	import cf_tls
{% endif %}
	@webhook path /webhook/*
	handle @webhook {
		reverse_proxy http://{{ traefik_vip | default('192.168.0.50') }}
	}
	handle {
		import authelia
		reverse_proxy http://{{ traefik_vip | default('192.168.0.50') }}
	}
}