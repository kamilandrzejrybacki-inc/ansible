# Meepmap (mapping app — via Traefik IngressRoute).
# /api/billing/webhook is the Stripe webhook ingress; it verifies the Stripe
# signature itself, so Authelia must NOT block those POSTs (same pattern as
# sentinel /webhook/*).
{{ _scheme }}{{ subdomain_meepmap | default('meepmap') }}.{{ domain }} {
	import rate_limit
	import proxy_headers
{% if cloudflare_api_token | default('') and not cf_tunnel_name | default('') %}
	import cf_tls
{% endif %}
	@stripe_webhook path /api/billing/webhook
	handle @stripe_webhook {
		reverse_proxy http://{{ traefik_vip | default('192.168.0.50') }}
	}
	# PWA manifest is fetched WITHOUT credentials by browsers, so Authelia 302s
	# it into a CORS error + service-worker failures. It is public, static app
	# metadata (name/icons) — safe to expose.
	@manifest path /manifest.webmanifest
	handle @manifest {
		reverse_proxy http://{{ traefik_vip | default('192.168.0.50') }}
	}
	handle {
		import authelia
		reverse_proxy http://{{ traefik_vip | default('192.168.0.50') }}
	}
}

