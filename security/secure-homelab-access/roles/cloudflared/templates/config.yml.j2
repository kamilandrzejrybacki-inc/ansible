tunnel: {{ cf_tunnel_id }}
credentials-file: {{ cloudflared_credentials_dir }}/{{ cf_tunnel_id }}.json
protocol: http2

ingress:
  # Route all subdomains and the root domain to Caddy
  - hostname: "{{ domain }}"
    service: http://localhost:80
  - hostname: "*.{{ domain }}"
    service: http://localhost:80
  # meepmap.com — primary public domain (separate CF zone, same tunnel + account).
  - hostname: "meepmap.com"
    service: http://localhost:80
  - hostname: "www.meepmap.com"
    service: http://localhost:80
  # Catch-all (required by cloudflared)
  - service: http_status:404
